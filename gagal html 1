<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>EPAI — Elite Personal AI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="style.css"/>
</head>
<body>

<!-- ═══════════════════════════ LOCK SCREEN ═══════════════════════════ -->
<div id="lockScreen">
  <canvas id="lockCanvas"></canvas>
  <div class="lock-orb l-orb1"></div>
  <div class="lock-orb l-orb2"></div>

  <div class="lock-card" id="lockCard">
    <div class="lock-emblem">
      <div class="emblem-ring"></div>
      <span class="emblem-letter">E</span>
    </div>
    <div class="lock-brand">
      <h1>EPAI</h1>
      <p>Elite Personal AI</p>
    </div>
    <div class="lock-tagline">Private Intelligence. Unlimited Control.</div>

    <div class="lock-field" id="lockField">
      <div class="field-prefix">⬡</div>
      <input type="password" id="passInput" placeholder="Enter access key" autocomplete="off"/>
      <button class="field-submit" onclick="checkPass()" id="submitBtn">
        <span>→</span>
      </button>
    </div>
    <div id="lockMsg" class="lock-msg"></div>

    <div class="lock-hint">Secured with end-to-end encryption</div>
  </div>
</div>

<!-- ═══════════════════════════ ACCESS OVERLAY ═══════════════════════════ -->
<div id="accessOverlay" class="access-overlay hidden">
  <div class="ao-content">
    <div class="ao-ring">
      <div class="ao-ring-inner"></div>
      <span class="ao-e">E</span>
    </div>
    <div class="ao-lines">
      <div class="ao-line" id="aol1">Verifying credentials<span class="cur">_</span></div>
      <div class="ao-line" id="aol2">Loading intelligence core<span class="cur">_</span></div>
      <div class="ao-line" id="aol3">Establishing secure session<span class="cur">_</span></div>
    </div>
    <div class="ao-granted hidden" id="aoGranted">ACCESS GRANTED</div>
    <div class="ao-ready hidden" id="aoReady">⬡ &nbsp; EPAI Online</div>
  </div>
</div>

<!-- ═══════════════════════════ MAIN APP ═══════════════════════════ -->
<div id="mainApp" class="hidden">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sb-top">
      <div class="sb-brand">
        <div class="sb-emblem">E</div>
        <div class="sb-brandtext">
          <span class="sb-name">EPAI</span>
          <span class="sb-tag">Elite Personal AI</span>
        </div>
      </div>

      <button class="btn-new-chat" onclick="newChat()">
        <span class="nc-icon">✦</span>
        <span>New Conversation</span>
      </button>
    </div>

    <div class="sb-section-label">CONVERSATIONS</div>
    <div class="chat-history" id="chatHistory">
      <!-- populated by JS -->
    </div>

    <div class="sb-bottom">
      <div class="sb-model-badge">
        <span class="model-dot"></span>
        <span id="modelLabel">Claude Sonnet 4</span>
      </div>
      <button class="sb-lock-btn" onclick="lockApp()">⬡ Lock Session</button>
    </div>
  </aside>

  <!-- SIDEBAR TOGGLE (mobile) -->
  <button class="sb-toggle" id="sbToggle" onclick="toggleSidebar()">☰</button>

  <!-- MAIN CHAT AREA -->
  <main class="chat-main" id="chatMain">

    <!-- Top bar -->
    <div class="chat-topbar">
      <div class="topbar-left">
        <div class="tb-status">
          <span class="tb-dot"></span>
          <span id="currentChatTitle">New Conversation</span>
        </div>
      </div>
      <div class="topbar-right">
        <button class="tb-btn" onclick="deleteCurrentChat()" title="Delete chat">⊗ Delete</button>
        <button class="tb-btn" onclick="exportChat()" title="Export">⎘ Export</button>
      </div>
    </div>

    <!-- Messages -->
    <div class="messages-wrap" id="messagesWrap">
      <!-- Welcome screen -->
      <div class="welcome-screen" id="welcomeScreen">
        <div class="wl-emblem">
          <div class="wl-ring"></div>
          <span>E</span>
        </div>
        <h2 class="wl-title">Good to see you.</h2>
        <p class="wl-sub">What would you like to explore today?</p>
        <div class="wl-chips">
          <button class="wl-chip" onclick="setPrompt('Summarize the key points of a topic I give you')">Summarize a topic</button>
          <button class="wl-chip" onclick="setPrompt('Help me write a professional email about')">Draft an email</button>
          <button class="wl-chip" onclick="setPrompt('Explain this concept in simple terms:')">Explain something</button>
          <button class="wl-chip" onclick="setPrompt('Analyze this text and give me insights:')">Analyze text</button>
        </div>
      </div>

      <!-- Messages container -->
      <div id="messagesList"></div>

      <!-- Typing indicator -->
      <div id="typingIndicator" class="typing-indicator hidden">
        <div class="typing-avatar">E</div>
        <div class="typing-bubble">
          <span class="typing-text">EPAI is thinking</span>
          <span class="typing-dots"><span></span><span></span><span></span></span>
        </div>
      </div>
    </div>

    <!-- Input area -->
    <div class="input-area">

      <!-- Attachment previews -->
      <div class="attachment-previews" id="attachmentPreviews"></div>

      <!-- Input toolbar -->
      <div class="input-toolbar">
        <div class="toolbar-left">
          <!-- File upload -->
          <div class="attach-group">
            <button class="attach-btn" title="Upload file" onclick="toggleAttachMenu(event)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
            </button>
            <div class="attach-menu hidden" id="attachMenu">
              <label class="am-item">
                <input type="file" id="fileUpload" accept=".pdf,.doc,.docx,.txt,.xlsx,.xls,.csv" hidden onchange="handleFileUpload(event)"/>
                <span class="am-icon">📁</span><span>Document</span>
                <span class="am-ext">PDF · DOCX · TXT · XLSX</span>
              </label>
              <label class="am-item">
                <input type="file" id="imageUpload" accept="image/*" hidden onchange="handleImageUpload(event)"/>
                <span class="am-icon">🖼️</span><span>Image</span>
                <span class="am-ext">JPG · PNG · WEBP</span>
              </label>
              <label class="am-item">
                <input type="file" id="audioUpload" accept="audio/*" hidden onchange="handleAudioUpload(event)"/>
                <span class="am-icon">🎤</span><span>Audio</span>
                <span class="am-ext">MP3 · WAV · M4A</span>
              </label>
              <label class="am-item">
                <input type="file" id="videoUpload" accept="video/*" hidden onchange="handleVideoUpload(event)"/>
                <span class="am-icon">🎥</span><span>Video</span>
                <span class="am-ext">MP4 · MOV · AVI</span>
              </label>
              <button class="am-item" onclick="openCamera()">
                <span class="am-icon">📷</span><span>Camera</span>
                <span class="am-ext">Take photo</span>
              </button>
            </div>
          </div>

          <!-- Voice input -->
          <button class="attach-btn" id="voiceBtn" title="Voice input" onclick="toggleVoice()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2M12 19v4M8 23h8"/></svg>
          </button>
        </div>

        <div class="input-box-wrap">
          <textarea id="messageInput" placeholder="Message EPAI…" rows="1"
            onkeydown="handleKeydown(event)"
            oninput="autoResize(this)"></textarea>
        </div>

        <button class="send-btn" id="sendBtn" onclick="sendMessage()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>

      <div class="input-footer">
        <span>EPAI · Private Session · <span id="msgCount">0</span> messages</span>
      </div>
    </div>

  </main>
</div>

<!-- ═══════════════════════════ CAMERA MODAL ═══════════════════════════ -->
<div class="modal-overlay hidden" id="cameraModal">
  <div class="modal-card">
    <div class="modal-header">
      <span class="modal-title">⬡ Camera Capture</span>
      <button class="modal-close" onclick="closeCamera()">✕</button>
    </div>
    <div class="camera-wrap">
      <video id="cameraVideo" autoplay playsinline></video>
      <canvas id="cameraCanvas" hidden></canvas>
      <img id="cameraPreview" class="hidden" alt="Preview"/>
    </div>
    <div class="modal-actions">
      <button class="btn-secondary" onclick="retakePhoto()" id="retakeBtn" style="display:none">Retake</button>
      <button class="btn-primary-modal" onclick="capturePhoto()" id="captureBtn">Capture</button>
      <button class="btn-primary-modal hidden" onclick="useCameraPhoto()" id="usePhotoBtn">Use Photo</button>
    </div>
  </div>
</div>

<script src="script.js"></script>
</body>
</html>
